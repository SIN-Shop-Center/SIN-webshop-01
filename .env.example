# Purpose: Environment variable template for Next.js 16 storefront (Step 2)
# Docs: PLAN-VERKAUFSFAEHIG.md (issues #20-#26)
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real secrets.
#
# SECURITY: Never put the Supabase IP/URL with credentials in this file.
# For self-hosted Supabase, set up HTTPS via reverse proxy (Caddy/Traefik)
# BEFORE exposing the API to any browser.

# ── Supabase (browser-safe) ───────────────────────────────────────────────────
# Public REST API URL of your Supabase project.
# Self-hosted: https://supabase.example.com  (MUST be HTTPS in production)
# supabase.com: https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-SUPABASE-URL"

# Anon key from Supabase project settings (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY="REPLACE_WITH_SUPABASE_ANON_KEY"

# ── Supabase (server-only, NEVER prefix with NEXT_PUBLIC_) ───────────────────
# Service role key bypasses RLS — server actions only.
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY"

# Direct PostgreSQL connection (optional, for seed scripts that bypass REST API)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Stripe (server-only, NEVER prefix with NEXT_PUBLIC_) ──────────────────────
# Get from https://dashboard.stripe.com/apikeys AFTER rotating old (leaked) keys
STRIPE_SECRET_KEY="sk_test_REPLACE_AFTER_ROTATION"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_AFTER_ROTATION"

# Public app URL (used by Stripe for success/cancel URLs)
# In Production: https://shopsin.delqhi.com (neuer Next.js Stack)
# Lokales Dev: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Resend (server-only email provider) ───────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY="re_REPLACE_WITH_RESEND_KEY"

# Verified sender address (defaults to onboarding@resend.dev for testing only)
# RESEND_FROM_EMAIL="SIN Shop <bestellung@delqhi.com>"

# ── CJ Dropshipping (server-only) ───────────────────────────────────────────
# Get from https://merchants.cjdropshipping.com → My CJ → Authorization
CJ_EMAIL="REPLACE_WITH_CJ_ACCOUNT_EMAIL"
CJ_API_KEY="REPLACE_WITH_CJ_API_KEY"

# Eure Marge auf den CJ-Einkaufspreis (z.B. 2.5 = 150% Aufschlag)
CJ_PRICE_MULTIPLIER="2.5"

# ── TikTok Shop Open Platform (server-only) ──────────────────────────────────
# App anlegen auf https://partner.tiktokshop.com → My Apps (Seller-App, Region EU)
# WICHTIG: NICHT developers.tiktok.com (Research API) — das ist die falsche API!
TIKTOK_APP_KEY="REPLACE_WITH_TIKTOK_APP_KEY"
TIKTOK_APP_SECRET="REPLACE_WITH_TIKTOK_APP_SECRET"

# Nach Seller-Autorisierung wird der auth_code an diese Callback-URL geliefert:
# https://DEINE-DOMAIN/api/tiktok/oauth/callback
# Der Callback tauscht den Code automatisch gegen Tokens und speichert sie in Supabase.

# Marge auf den CJ-Einkaufspreis für TikTok-Listings (TikTok-Gebühren ~5-15% einkalkulieren)
TIKTOK_PRICE_MULTIPLIER="2.8"

# Währung der TikTok-Listings (DE-Shop = EUR)
TIKTOK_CURRENCY="EUR"

# Versanddienstleister-ID für TikTok-Tracking-Rückmeldung
# (einmalig via getShippingProviders ermitteln oder im Seller Center nachsehen)
TIKTOK_SHIPPING_PROVIDER_ID="REPLACE_WITH_SHIPPING_PROVIDER_ID"

# Basis-URL der App (für OAuth-Redirect)
NEXT_PUBLIC_APP_URL="https://DEINE-DOMAIN"

# Alerting bei Pipeline-Fehlern (nutzt bestehendes Resend-Setup)
ALERT_EMAIL="dein-name@example.com"

# Mindest-Trend-Score für CJ-Import-Kandidaten (Stufe 1 → 2)
MIN_TREND_SCORE="60"

# Retouren unter diesem Betrag (EUR) automatisch genehmigen
TIKTOK_RETURN_AUTO_APPROVE_LIMIT="15"

# Geschätzte TikTok-Provision in Prozent (für den Wochenreport)
TIKTOK_COMMISSION_PCT="9"

# ── Cron-Authentifizierung (server-only) ─────────────────────────────────────
# Generate: openssl rand -hex 32
# Vercel Cron sendet automatisch Authorization: Bearer $CRON_SECRET
CRON_SECRET="REPLACE_WITH_OPENSSL_RAND_HEX_32"

# ── Pricing & FX (Issue #35) ─────────────────────────────────────────────────
# Fallback USD→EUR Wechselkurs wenn DB-Wert fehlt/veraltet
FX_RATE_USD_EUR="0.92"

# ── Resend Webhook (Issue #43) ───────────────────────────────────────────────
# Signatur-Verifikation für Bounce/Complaint-Events
# Resend Dashboard → Webhooks → svix-Secret kopieren
RESEND_WEBHOOK_SECRET="whsec_REPLACE_WITH_RESEND_WEBHOOK_SECRET"

# ── Monitoring Push-URLs (Issue #39) ─────────────────────────────────────────
# Uptime-Kuma → Add Monitor → Type "Push" → URL kopieren
# Cron-Endpoints pingen diese URLs nach jedem Lauf
KUMA_PUSH_CJ_SYNC=""
KUMA_PUSH_CJ_FULFILLMENT=""
KUMA_PUSH_FX_UPDATE=""
KUMA_PUSH_TIKTOK_ORDERS=""

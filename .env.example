# Purpose: Environment variable template for Next.js 16 storefront
# Docs: AGENTS.md
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real secrets.
#
# ===== Supabase (self-hosted via Cloudflare Tunnel) =====
# WICHTIG: https, KEIN Port. Port 8006 ist NUR die interne Tunnel-Ingress-Adresse.
NEXT_PUBLIC_SUPABASE_URL=https://supabase.delqhi.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# NUR serverseitig verwenden. NIEMALS NEXT_PUBLIC_-Prefix.
SUPABASE_SERVICE_ROLE_KEY=

# ===== Stripe =====
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== App =====
NEXT_PUBLIC_APP_URL=https://shopsin.delqhi.com

# ===== Resend (Email) =====
RESEND_API_KEY=

# ===== CJ Dropshipping =====
CJ_EMAIL=
CJ_API_KEY=
CJ_PRICE_MULTIPLIER=2.5

# ===== TikTok Shop =====
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_PRICE_MULTIPLIER=2.8
TIKTOK_CURRENCY=EUR
TIKTOK_SHIPPING_PROVIDER_ID=

# ===== Cron =====
CRON_SECRET=

# ===== Pricing =====
FX_RATE_USD_EUR=0.92

# ===== Monitoring =====
KUMA_PUSH_CJ_SYNC=
KUMA_PUSH_CJ_FULFILLMENT=
KUMA_PUSH_FX_UPDATE=
KUMA_PUSH_TIKTOK_ORDERS=

# Purpose: Environment variable template for Next.js 16 storefront (Step 2)
# Docs: PLAN-VERKAUFSFAEHIG.md (issues #20-#26)
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real secrets.

# ── Supabase (self-hosted on OCI VM 92.5.60.87) ──
# Public URL of the Supabase REST API (Kong gateway).
# For self-hosted: http://92.5.60.87:8000
# For supabase.com: https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL="http://92.5.60.87:8000"

# Anon key from Supabase project settings (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY="REPLACE_WITH_SUPABASE_ANON_KEY"

# Service role key (server-side only, NEVER expose to browser)
# Used by seed scripts and admin operations.
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY"

# Direct PostgreSQL connection (optional, for scripts that bypass Supabase API)
# DATABASE_URL="postgresql://simone:simone123@92.5.60.87:5433/postgres"

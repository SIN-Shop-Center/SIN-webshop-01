# ============================================================
# SIMONE-WEBSHOP-01 - Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ===================
# DATABASE
# ===================
DB_PASSWORD=simone123
DATABASE_URL=postgresql://simone:simone123@localhost:5432/simone_shop

# ===================
# SUPABASE (External - for production)
# ===================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===================
# AI APIs (FREE!)
# ===================
# OpenCode Zen - Primary AI (FREE, unlimited)
OPENCODE_ZEN_API_KEY=your-opencode-zen-key
OPENCODE_ZEN_MODEL=grok-code

# Mistral - Vision tasks (FREE tier)
MISTRAL_API_KEY=your-mistral-key

# Gemini - Voice AI (FREE tier)
GEMINI_API_KEY=your-gemini-key

# NVIDIA - UGC video generation
# If these are unset, the UGC worker falls back to concept-mode outputs.
NVIDIA_API_KEY=
NVIDIA_REASON_URL=
NVIDIA_PREDICT_URL=
# Optional second pass. Leave empty while tuning hosted rate limits.
NVIDIA_TRANSFER_URL=
# Start konservativ: 1 echter Live-Render, Rest als Konzept-Fallback.
NVIDIA_MAX_LIVE_VARIANTS_PER_RUN=1
# Mindestabstand zwischen zwei NVIDIA-Requests im Worker.
NVIDIA_MIN_REQUEST_INTERVAL_MS=12000
# Modal bulk renderer for fast/balanced lanes.
MODAL_API_TOKEN=
MODAL_RENDER_URL=
# Optional. Can contain {job_id}; otherwise job_id is appended as query param.
MODAL_STATUS_URL=
MODAL_POLL_INTERVAL_MS=5000
MODAL_REQUEST_TIMEOUT_SECONDS=480
MODAL_MAX_VARIANTS_PER_RUN=6

# ===================
# PAYMENTS
# ===================
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox

# Klarna
KLARNA_API_KEY=your-klarna-key
KLARNA_API_SECRET=your-klarna-secret

# ===================
# N8N WORKFLOW ENGINE
# ===================
N8N_USER=admin
N8N_PASSWORD=simone2026
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ===================
# TRANSACTIONAL EMAIL (GMAIL API + SERVICE ACCOUNT)
# ===================
# Der gleiche Service Account wird auch fuer Google-Doc-Imports im TikTok-Registrierungsflow genutzt.
# Das betreffende Dokument muss direkt mit der Service-Account-E-Mail geteilt sein.
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
# GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google-service-account.json
GMAIL_DELEGATED_USER=info@um-24.de
GMAIL_SENDER_FROM="Simone Shop <info@um-24.de>"
GMAIL_API_BASE_URL=https://gmail.googleapis.com
GOOGLE_DOCS_API_BASE_URL=https://docs.googleapis.com

# ===================
# SOCIAL MEDIA (ClawdBot)
# ===================
# Twitter/X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Instagram
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# WhatsApp Business
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Telegram
TELEGRAM_BOT_TOKEN=

# TikTok
TIKTOK_ACCESS_TOKEN=
TIKTOK_SHOP_CLIENT_KEY=
TIKTOK_SHOP_CLIENT_SECRET=
TIKTOK_SHOP_REDIRECT_URI=
TIKTOK_SHOP_CODE_VERIFIER=
# Or provide a precomputed code challenge instead of the verifier
TIKTOK_SHOP_CODE_CHALLENGE=
TIKTOK_SHOP_CONNECT_SCOPES=user.info.basic
TIKTOK_SHOP_CONNECT_URL=
TIKTOK_SHOP_TOKEN_URL=
TIKTOK_SHOP_MERCHANT_TOKEN_URL=
TIKTOK_SHOP_PRODUCT_OPT_SHOPS_URL=
TIKTOK_SHOP_TARGET_IDC=
TIKTOK_SHOP_CALLBACK_SECRET=
TIKTOK_BROWSER_RUNNER_TOKEN=
TIKTOK_BROWSER_METADATA_RUNNER_URL=
TIKTOK_BROWSER_CDP_URL=
TIKTOK_BROWSER_EXECUTABLE_PATH=
# Wenn leer, versucht die Web-Runtime lokal typische Chrome/Chromium-Pfade selbst zu finden.
TIKTOK_BROWSER_HEADLESS=true
TIKTOK_BROWSER_SESSION_DATA_DIR=

# ===================
# MARKETPLACES
# ===================
# eBay
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_AUTH_TOKEN=

# eBay Kleinanzeigen
EBAY_KA_USERNAME=
EBAY_KA_PASSWORD=

# ===================
# ADMIN
# ===================
ADMIN_EMAIL=simone@example.com
ADMIN_PASSWORD=secure-password-here
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars

# ===================
# MISC
# ===================
NEXT_PUBLIC_APP_URL=https://your-domain.com
SITE_URL=https://your-domain.com
NEXT_PUBLIC_IMAGE_REMOTE_ALLOWLIST=picsum.photos
NEXT_PUBLIC_SHOP_NAME=Simone's Shop
NEXT_PUBLIC_CURRENCY=EUR
NEXT_PUBLIC_LOCALE=de-DE
# Production default must remain false. Enable only for local/dev debugging.
NEXT_PUBLIC_WEB_CATALOG_FALLBACK_ENABLED=false
NEXT_PUBLIC_WEB_ACCOUNT_FALLBACK_ENABLED=false

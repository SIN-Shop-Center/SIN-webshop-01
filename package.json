{
  "name": "simone-micro-commerce-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*",
    "tests/*"
  ],
  "scripts": {
    "prebuild": "node scripts/ensure-supported-node.mjs",
    "pretypecheck": "node scripts/ensure-supported-node.mjs",
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:web": "pnpm --filter @simone/web dev",
    "dev:storefront": "pnpm dlx wrangler dev --config workers/cloudflare/wrangler.toml --local --port 3000",
    "dev:api": "cd apps/api && go run ./cmd/api",
    "dev:worker": "cd apps/api && go run ./cmd/worker",
    "deploy:cloudflare": "bash ./scripts/deploy-cloudflare-worker.sh",
    "seed": "node scripts/supabase/seed-products.mjs",
    "seed:dev": "node scripts/supabase/seed-products.mjs --dev",
    "build": "pnpm -r --if-present build",
    "test": "node scripts/ensure-supported-node.mjs && pnpm run check:governance && node --test scripts/lib/cli-env.test.mjs scripts/lib/google-api.test.mjs scripts/lib/web-production-env.test.mjs scripts/governance-doc-sync.test.mjs scripts/project-ssot-doc-sync.test.mjs scripts/google-secret-sync.test.mjs scripts/sin-a2a-doc-sync.test.mjs scripts/check-governance-preflight.test.mjs scripts/storefront-legal-sync.test.mjs scripts/guard-baseline-validate.test.mjs && pnpm -r --if-present test && pnpm test:api",
    "test:api": "node scripts/ensure-supported-node.mjs && node scripts/test-api-essential.mjs",
    "test:api:native": "cd apps/api && go test ./...",
    "test:api:full": "cd apps/api && go test ./...",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "check:governance": "node scripts/check-governance-preflight.mjs",
    "guard:lines": "node scripts/guard-lines.mjs",
    "guard:baseline:validate": "node scripts/guard-baseline-validate.mjs",
    "guard:baseline": "pnpm run guard:baseline:validate",
    "guard:complexity": "node scripts/guard-complexity.mjs",
    "check:migrations": "node scripts/migration-audit.mjs",
    "check:fallbacks": "node scripts/ensure-supported-node.mjs && node scripts/check-prod-fallbacks.mjs",
    "check:routes": "node scripts/check-web-routes.mjs",
    "check:browser-automator": "node scripts/check-browser-automator-py.mjs",
    "check:web:runtime": "node scripts/ensure-supported-node.mjs && WEB_RUNTIME_AUTO_STUB_API=true node scripts/check-web-runtime.mjs",
    "check:web:runtime:lenient": "node scripts/ensure-supported-node.mjs && WEB_RUNTIME_REQUIRE_HEALTHY_API=false node scripts/check-web-runtime.mjs",
    "check:web:runtime:strict": "node scripts/ensure-supported-node.mjs && WEB_RUNTIME_REQUIRE_HEALTHY_API=true node scripts/check-web-runtime.mjs",
    "check:env:template": "node scripts/ensure-supported-node.mjs && node scripts/check-live-env-template.mjs",
    "check:env:live": "node scripts/ensure-supported-node.mjs && node scripts/check-live-env.mjs",
    "sync:gdoc:browser-governance": "node scripts/push-browser-governance-to-gdoc.mjs",
    "sync:gdoc:project-ssot": "node scripts/sync-project-ssot-doc.mjs",
    "sync:gdoc:storefront-governance": "node scripts/push-storefront-governance-to-gdoc.mjs",
    "sync:google:cloudflare-key": "node scripts/push-cloudflare-key-to-google.mjs",
    "secrets:bootstrap": "bash scripts/secrets-bootstrap.sh",
    "secrets:decrypt": "bash scripts/secrets-decrypt.sh",
    "secrets:edit": "bash scripts/secrets-edit.sh",
    "secrets:pubkey": "bash scripts/secrets-pubkey.sh",
    "secrets:run": "bash scripts/secrets-run.sh",
    "spm:agent": "pnpm --filter @simone/spm-a2a start",
    "spm:ctl": "node scripts/spm-ctl-wrapper.mjs",
    "spm:bootstrap": "pnpm --filter @simone/spm-a2a bootstrap",
    "spm:import:sops": "pnpm --filter @simone/spm-a2a import:sops",
    "spm:mcp": "pnpm --filter @simone/spm-secret-sync-mcp start",
    "spm:mcp:http": "pnpm --filter @simone/spm-secret-sync-mcp start:http",
    "hf:deploy:agent": "node scripts/deploy-sin-a2a-agent-to-hf.mjs",
    "sin-a2a:scaffold": "node scripts/scaffold-sin-a2a-agent.mjs",
    "sin-a2a:sync:gdoc": "node scripts/sync-sin-a2a-agent-to-gdoc.mjs",
    "sin-a2a:install:opencode": "node scripts/install-opencode-sin-a2a.mjs",
    "smoke:go-live": "node scripts/ensure-supported-node.mjs && node scripts/go-live-smoke.mjs",
    "go-live:today": "node scripts/ensure-supported-node.mjs && pnpm run check:governance && pnpm run check:env:live -- --with-smoke && pnpm run ci && pnpm run check:web:runtime:strict && pnpm smoke:go-live",
    "ci": "node scripts/ensure-supported-node.mjs && pnpm run check:governance && pnpm lint && node scripts/with-web-production-env.mjs pnpm build && pnpm check:fallbacks && pnpm check:web:runtime && pnpm typecheck && pnpm guard:lines && pnpm guard:baseline && pnpm guard:complexity && pnpm check:env:template && pnpm check:migrations && pnpm check:routes && pnpm check:browser-automator && pnpm test"
  },
  "engines": {
    "node": ">=20.9.0 <25"
  },
  "devDependencies": {}
}
